function runMenuAction_(question, successTitle, action) {
  var ui = SpreadsheetApp.getUi();
  var response = ui.alert("Muhasebe Bakım", question, ui.ButtonSet.YES_NO);

  if (response !== ui.Button.YES) {
    ui.alert("İşlem iptal edildi.");
    return;
  }

  var result = action();
  ui.alert(successTitle, JSON.stringify(result, null, 2), ui.ButtonSet.OK);
}
